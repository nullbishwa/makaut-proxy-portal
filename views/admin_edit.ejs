<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload PDF Result</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f6f9; padding: 30px; display: flex; justify-content: center; }
        .form-box { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); width: 100%; max-width: 500px; }
        h3 { color: #004080; margin-top: 0; }
        label { display: block; font-weight: bold; margin-bottom: 10px; margin-top: 15px; }
        input[type="file"] { width: 100%; padding: 10px; border: 1px dashed #ccc; background: #fafafa; border-radius: 4px; box-sizing: border-box; cursor: pointer; }
        button { background: #4cae4c; color: white; border: none; padding: 12px; width: 100%; border-radius: 4px; font-size: 16px; font-weight: bold; cursor: pointer; margin-top: 20px; }
        button:hover { background: #449d44; }
        .back-link { display: inline-block; margin-top: 15px; color: #337ab7; text-decoration: none; }
    </style>
</head>
<body>
    <div class="form-box">
        <h3>Upload Result PDF for Roll: <%= rollNo %></h3>
        <form action="/api/admin/save-override" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="roll_no" value="<%= rollNo %>">
            <label>Select Result File (PDF format only):</label>
            <input type="file" name="result_pdf" accept="application/pdf" required>
            <button type="submit">Upload File to MongoDB</button>
        </form>
        <a href="/admin/dashboard" class="back-link">&larr; Back to Dashboard</a>
    </div>
</body>
</html>
